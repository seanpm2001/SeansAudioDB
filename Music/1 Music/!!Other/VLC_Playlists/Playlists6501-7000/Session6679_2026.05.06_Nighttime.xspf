			<location>file:///home/seanpm2001/Desktop/SeansLifeArchive/Extras/Audio/1%20Music/Oregon%20Trail%20-%20American%20Settler%20OST/MP3/The-Oregon-Trail_American-Settler_Music-uncut-trailer.mp3</location>
			<title>The-Oregon-Trail_American-Settler_Music-uncut-trailer.mp3</title>
			<creator>Gameloft</creator>
			<album>The Oregon Trail: American Settler soundtrack</album>
